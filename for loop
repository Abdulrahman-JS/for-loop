import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
  Scanner input = new Scanner(System.in);
  System.out.println("Enter an n: ");
      int n = input.nextInt();
      for(int i=1; i<=n*n; i++){
          System.out.print("* ");
   if (i%n==0){
       System.out.println();
   }
      }
    }
}
